generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//user model login/signup
model User {
  id          Int            @id @default(autoincrement())
  name        String?
  email       String         @unique
  mobile      String         @unique
  password    String
  preferences String?        @db.Text // Store JSON string for AI context
  createdAt   DateTime       @default(now())
  journals    JournalEntry[]
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  sentiment String?  @db.Text // JSON result from AI
  emotion   String?  // happy, stress, etc.
  riskLevel String?  // low, medium, high
  createdAt DateTime @default(now())
}

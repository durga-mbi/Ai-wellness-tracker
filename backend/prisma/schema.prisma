generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//user model login/signup
model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  mobile    String   @unique
  password  String
  createdAt DateTime @default(now())
}

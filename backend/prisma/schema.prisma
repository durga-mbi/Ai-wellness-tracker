generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//user model login/signup
model User {
  id          String         @id @default(auto()) @map("_id") @db.ObjectId
  name        String?
  email       String?        @unique // nullable for guest account
  mobile      String?        @unique // nullable for guest account
  password    String?        // nullable for guest account
  ageGroup    String?        // e.g., "18-24"
  university  String?        // user's university
  isAnonymous Boolean        @default(false)
  preferences String?        // JSON string for AI context
  apiKey      String?        // User-provided Gemini API key
  createdAt   DateTime       @default(now())
  journals    JournalEntry[]
  preferenceList Preference[]
  userHabits     UserHabit[]
  forumPosts     ForumPost[]
  postLikes      PostLike[]
}

model ForumPost {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  content     String
  userId      String     @db.ObjectId
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAnonymous Boolean    @default(true)
  likesCount  Int        @default(0) // Cache for performance
  likes       PostLike[]
  reports     Int        @default(0)
  createdAt   DateTime   @default(now())
}

model PostLike {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  postId    String    @db.ObjectId
  userId    String    @db.ObjectId
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
}

model JournalEntry {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  sentiment String?  // JSON result from AI
  emotion   String?  // happy, stress, etc.
  riskLevel String?  // low, medium, high
  createdAt DateTime @default(now())
}

model Preference {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  issue  String
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// user habits
model UserHabit {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sleep     Float?   // in hours
  water     Float?   // in liters
  exercise  Float?   // in minutes
  date      DateTime @default(now()) // The day for this habit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date]) // optional, for faster queries by user & date
}


//crises detection model
model CrisisLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId // Optional, can still be an ObjectID if provided
  source    String   // "journal" | "chat" | "forum"
  message   String
  riskLevel String   // LOW | MEDIUM | HIGH
  alertSent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([riskLevel])
}
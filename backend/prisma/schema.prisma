generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//user model login/signup
model User {
  id          Int            @id @default(autoincrement())
  name        String?
  email       String         @unique
  mobile      String         @unique
  password    String
  preferences String?        @db.Text // Store JSON string for AI context
  createdAt   DateTime       @default(now())
  journals    JournalEntry[]
  preferenceList Preference[]
  userHabits     UserHabit[]
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  sentiment String?  @db.Text // JSON result from AI
  emotion   String?  // happy, stress, etc.
  riskLevel String?  // low, medium, high
  createdAt DateTime @default(now())
}

model Preference {
  id     Int    @id @default(autoincrement())
  issue  String
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// user habits
model UserHabit {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sleep     Float?   // in hours
  water     Float?   // in liters
  exercise  Float?   // in minutes
  date      DateTime @default(now()) // The day for this habit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date]) // optional, for faster queries by user & date
}
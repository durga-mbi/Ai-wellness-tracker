generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//user model login/signup
model User {
  id          Int            @id @default(autoincrement())
  name        String?
  email       String?        @unique // nullable for guest account
  mobile      String?        @unique // nullable for guest account
  password    String?        // nullable for guest account
  ageGroup    String?        // e.g., "18-24"
  university  String?        // user's university
  isAnonymous Boolean        @default(false)
  preferences String?        @db.Text // Store JSON string for AI context
  createdAt   DateTime       @default(now())
  journals    JournalEntry[]
  preferenceList Preference[]
  userHabits     UserHabit[]
  forumPosts     ForumPost[]
  postLikes      PostLike[]
}

model ForumPost {
  id          Int        @id @default(autoincrement())
  content     String     @db.Text
  userId      Int
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAnonymous Boolean    @default(true)
  likesCount  Int        @default(0) // Cache for performance
  likes       PostLike[]
  reports     Int        @default(0)
  createdAt   DateTime   @default(now())
}

model PostLike {
  id        Int       @id @default(autoincrement())
  postId    Int
  userId    Int
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([postId, userId])
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  sentiment String?  @db.Text // JSON result from AI
  emotion   String?  // happy, stress, etc.
  riskLevel String?  // low, medium, high
  createdAt DateTime @default(now())
}

model Preference {
  id     Int    @id @default(autoincrement())
  issue  String
  userId Int
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}


// user habits
model UserHabit {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sleep     Float?   // in hours
  water     Float?   // in liters
  exercise  Float?   // in minutes
  date      DateTime @default(now()) // The day for this habit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date]) // optional, for faster queries by user & date
}


//crises detection model
model CrisisLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     // optional, no relation
  source    String   // "journal" | "chat" | "forum"
  message   String   @db.Text
  riskLevel String   // LOW | MEDIUM | HIGH
  alertSent Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([riskLevel])
}